<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop">
  <id>@Launcher_AppID@</id>
  <name>@Launcher_CommonName@</name>
  <summary>Custom Minecraft Launcher to easily manage multiple Minecraft installations at once</summary>
  <developer id="io.github.cleanlauncher">
    <name>@Launcher_CommonName@</name>
  </developer>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-only</project_license>
  <description>
    <p>@Launcher_CommonName@ is a custom launcher for Minecraft that focuses on predictability, long term stability and simplicity.</p>
    <p>Features:</p>
    <ul>
      <li>Easily install game modifications, such as Fabric, Forge and Quilt</li>
      <li>Easily install and update modpacks from the Launcher</li>
      <li>Control your Java settings, and enable Mangohud or Gamemode with a toggle</li>
      <li>Manage worlds and resource packs from the launcher</li>
      <li>See logs and other details easily through a dashboard</li>
      <li>Kill Minecraft in case of a crash/freeze</li>
      <li>Isolate Minecraft instances to keep everything clean</li>
      <li>Install and update mods directly from the launcher</li>
      <li>Customize the launcher with themes, and more</li>
      <li>And cat :3</li>
    </ul>
  </description>
  <screenshots>
    <!-- Add your own screenshots here. Example:
    <screenshot type="default">
      <caption>The main window</caption>
      <image type="source" width="1030" height="764">https://example.com/screenshots/main.png</image>
    </screenshot>
    -->
  </screenshots>
  <releases>
    <release version="@Launcher_VERSION_NAME@" date="@Launcher_BUILD_TIMESTAMP@"></release>
  </releases>
  <url type="homepage">@Launcher_Git@</url>
  <url type="bugtracker">@Launcher_Git@/issues</url>
  <url type="help">@Launcher_Git@/wiki</url>
  <url type="vcs-browser">@Launcher_Git@</url>
  <url type="contribute">@Launcher_Git@/blob/develop/CONTRIBUTING.md</url>
  <content_rating type="oars-1.1">
    <content_attribute id="violence-fantasy">moderate</content_attribute>
    <content_attribute id="social-chat">intense</content_attribute>
  </content_rating>
  <launchable type="desktop-id">@Launcher_AppID@.desktop</launchable>
</component>
